{
  "name": "sauce-demo-automation",
  "version": "1.0.0",
  "description": "Playwright + TypeScript test automation framework for SauceDemo",
  "scripts": {
    "test": "playwright test",
    "test:auth": "playwright test src/tests/auth",
    "test:catalog": "playwright test src/tests/catalog",
    "test:cart": "playwright test src/tests/cart",
    "test:checkout": "playwright test src/tests/checkout",
    "test:performance": "playwright test src/tests/performance",
    "test:headed": "playwright test --headed",
    "test:allure": "playwright test --reporter=line,allure-playwright",
    "report": "playwright show-report",
    "report:allure": "allure generate ./allure-results --clean && allure open",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "allure-commandline": "^2.38.1",
    "allure-js-commons": "^3.6.0",
    "allure-playwright": "^3.6.0",
    "dotenv": "^16.6.1",
    "eslint": "^8.57.1",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IsratJn/sauce-demo-automation.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
